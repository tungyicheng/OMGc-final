#include <iostream>
#include <vector>
#include <memory>    // 使用 shared_ptr 必須引入此標頭檔
#include <algorithm> // 使用 std::sort 必須引入此標頭檔
using namespace std;

// ==========================================
// 基礎類別：學生 (Student)
// ==========================================
class Student {
public:
    // Check Point 1 (5%): 構造函式，初始化學生基本資料與總分
    Student(string name, int student_id, int math_score, int english_score) {
        this->name = name;
        this->student_id = student_id;
        this->math_score = math_score;
        this->english_score = english_score;
        this->total_score = math_score + english_score; // 自動計算總分
    }
    
    // 學生屬性（資料成員）
    string name;
    int student_id;
    int math_score;
    int english_score;
    int total_score;

    // Check Point 3 (5%): 虛擬函式 (virtual)，允許衍生類別進行覆寫 (Override) 以實作動態多型
    virtual void print() {
        cout << "Name: " << name << endl;
        cout << "Student ID: " << student_id << endl;
        cout << "Math Score: " << math_score << endl;
        cout << "English Score: " << english_score << endl;
        cout << "Total Score: " << total_score << endl;
    }
};

// ==========================================
// 獨立函式：選擇排序法 (Selection Sort)
// ==========================================
// Check Point 2 (55%): 透過「學生學號 (student_id)」由小到大排序學生陣列
void mySort(vector<Student> & students) {
    for (int i = 0; i < students.size(); i++) {
        int minIndex = i; // 記錄目前未排序區段中的最小值索引
        for (int j = i + 1; j < students.size(); j++) {
            // 如果找到更小的學號，更新最小值索引
            if (students[j].student_id < students[minIndex].student_id) {
                minIndex = j;
            }
        }
        // 如果最小值索引改變，則與目前位置 i 的元素交換
        if (minIndex != i) {
            Student t = students[i];
            students[i] = students[minIndex];
            students[minIndex] = t;
        }
    }
}

// ==========================================
// 衍生類別：高中生 (HighSchoolStudent)
// ==========================================
// Check Point 4 (5%): 繼承自 Student 類別
class HighSchoolStudent: public Student {
public:
    // 構造函式：利用初始化列表呼叫基礎類別的構造函式
    HighSchoolStudent(string name, int student_id, int math_score, int english_score):
        Student(name, student_id, math_score, english_score) {
    }
    string highschool_name; // 高中名稱成員（此範例暫未初始化）
    
    // 覆寫 print() 函式，額外輸出 Category 資訊
    void print() override {
        cout << "Name: " << name << endl;
        cout << "Student ID: " << student_id << endl;
        cout << "Category: " << "HighSchoolStudent" << endl;
        cout << "Math Score: " << math_score << endl;
        cout << "English Score: " << english_score << endl;
        cout << "Total Score: " << total_score << endl;
    }
