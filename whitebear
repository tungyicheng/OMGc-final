// ==========================================
// 排序比較用仿函式 (Functor)
// ==========================================
class TotalScoreCmp {
public:
    // 多載 () 運算子，比較兩個學生智慧指標的「總分」大小
    bool operator()(shared_ptr<Student> s1, shared_ptr<Student> s2) {
        return s1->total_score < s2->total_score; 
    }
};

// ==========================================
// 管理類別：學生管理系統 (StudentManager)
// ==========================================
class StudentManager {
public:
    // 使用 shared_ptr 儲存學生，用來支援多型並自動管理記憶體
    vector<shared_ptr<Student>> students;
    
    // Check Point 5 (5%): 新增學生，並檢查學號是否重複
    void addStudent(shared_ptr<Student> s) {
        for (int i = 0; i < students.size(); i++) {
            // 若學號已存在，則放棄加入，確保學號唯一性
            if (students[i]->student_id == s->student_id) {
                return;
            }
        }
        students.push_back(s);
    }
    
    // Check Point 6 (5%): 遍歷並呼叫每個學生的 print() 函式
    void printStudents() {
        for (int i = 0; i < students.size(); i++) {
            students[i]->print(); // 這裡會根據物件實際型態發揮「多型」效果
        }
    }
    
    // Check Point 7 (5%): 使用仿函式 (TotalScoreCmp) 依總分從小到大排序
    void sortByTotalScore() {
        TotalScoreCmp cmp;
        sort(students.begin(), students.end(), cmp);
    }

    // Check Point 8 (5%): 使用 Lambda 運算式進行多條件排序
    void sortByMathScoreThenEnglishScore() {
        sort(students.begin(), students.end(),
            [](shared_ptr<Student> s1, shared_ptr<Student> s2) {
                // 優先比較數學分數
                if (s1->math_score < s2->math_score) {
                    return true;
                } 
                // 若數學分數相同，則比較英文分數
                else if (s1->math_score == s2->math_score &&
                         s1->english_score < s2->english_score) {
                    return true;
                }
                return false;
            });
    }
};

// ==========================================
// 主程式進入點 (main)
// ==========================================
int main() {

    // --- 第一部分：測試自訂的選擇排序法 (mySort) ---
    // Check Point 2 (55%): 建立未排序的學生 vector
    vector<Student> students = {
        Student("John", 5, 90, 80),
        Student("Bob", 3, 95, 85),
        Student("Jeff", 2, 85, 70)
    };
    
    mySort(students); // 執行排序（依學號 2 -> 3 -> 5）
    
    // 印出排序後的基礎學生資料
    for (int i = 0; i < students.size(); i++) {
        students[i].print();
    }

    cout << "-----------------------------------" << endl;

    // --- 第二部分：測試學生管理系統與多型 ---
    StudentManager manager;
    
    // 建立高中生與大學生物件
    HighSchoolStudent student0 = HighSchoolStudent("Wang", 6, 100, 100);
    HighSchoolStudent student1 = HighSchoolStudent("Wang", 8, 80, 80);
    CollegeStudent student2 = CollegeStudent("Lin", 7, 90, 90);
    CollegeStudent student3 = CollegeStudent("Kobayashi", 7, 90, 90); // 學號 7 與 Lin 重複
    
    // 【重要提示】這裡原程式碼使用 make_shared<Student>(student0) 會發生「物件截斷 (Slicing)」
    // 它只複製了基礎類別 Student 的部分，導致後續無法觸發 HighSchoolStudent 的 print()。
    manager.addStudent(make_shared<Student>(student0));
    manager.addStudent(make_shared<Student>(student1));
    manager.addStudent(make_shared<Student>(student2));
    
    // Check Point 9 (5%): 因為 Kobayashi 的學號是 7，與 Lin 重複，所以不會被加入
    manager.addStudent(make_shared<Student>(student3));
    
    // Check Point 10 (5%): 執行排序並輸出結果
    // manager.sortByTotalScore(); // 依總分排序（已被註解）
    manager.sortByMathScoreThenEnglishScore(); // 依數學、英文分數排序
    
    manager.printStudents(); // 列印管理系統內的所有學生
    
    return 0;
}